{
  "compilerOptions": {
    "target": "es5",
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "forceConsistentCasingInFileNames": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "node",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "baseUrl": ".",
    "paths": {
      "@api/*": ["api/*"],
      "@config/*": ["config/*"],
      "@templates/*": ["@templates/*"],
      "@styles/*": ["styles/*"],
      "@typings/*": ["typings/*"],
      "@features/*": ["features/*"],
      "@fonts": ["./styles/font/*"]
    },
    "allowImportingTsExtensions": true
  },
  "include": ["next-env.d.ts", "**/*.ts", "**/*.tsx", "next-seo.config.js"],
  "exclude": ["node_modules"]
}
